{
  "info": {
    "name": "Payments API",
    "_postman_id": "a1b2c3d4-5678-90ab-cdef-1234567890ab",
    "description": "Collection for testing Spring Boot Payments API with Idempotency-Key support",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Create Payment",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Idempotency-Key", "value": "{{$guid}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"amount\": 100.00,\n  \"currency\": \"USD\",\n  \"description\": \"Test payment\"\n}"
        },
        "url": {
          "raw": "http://localhost:8080/payments",
          "protocol": "http",
          "host": ["localhost"],
          "port": "8080",
          "path": ["payments"]
        }
      }
    },
    {
      "name": "Get Payment by ID",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "http://localhost:8080/payments/1",
          "protocol": "http",
          "host": ["localhost"],
          "port": "8080",
          "path": ["payments", "1"]
        }
      }
    },
    {
      "name": "Get All Payments",
      "request": {
        "method": "GET",
